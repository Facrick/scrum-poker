# ──────────────────────────────────────────────────────────────────
# Переменные окружения для Railway
# Задаются в Railway Dashboard → Variables (НЕ коммитить реальные значения!)
# ──────────────────────────────────────────────────────────────────

# Домен приложения (CORS + WebSocket)
# На Railway: https://<your-project>.up.railway.app  или  https://ваш-домен.com
ALLOWED_ORIGIN=https://poker.yourcompany.com

# Через сколько часов удалять неактивные комнаты
ROOM_TTL_HOURS=8

# PostgreSQL — Railway подставляет автоматически при добавлении плагина Postgres.
# Скопируйте значение из Railway Dashboard → Postgres → Variables → DATABASE_URL
# и преобразуйте формат: postgres://user:pass@host:port/db  →  jdbc:postgresql://...
DATABASE_URL=jdbc:postgresql://host:5432/scrumpoker?user=poker&password=your_password
DB_DRIVER=org.postgresql.Driver

# OAuth2 — ЛК модераторов
# Google: console.cloud.google.com → Credentials → OAuth client ID
#   Authorized redirect URI: https://ваш-домен.com/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub: github.com → Settings → Developer settings → OAuth Apps
#   Authorization callback URL: https://ваш-домен.com/login/oauth2/code/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
