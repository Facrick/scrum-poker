# Скопируйте в .env и заполните перед деплоем
# cp .env.example .env

# Домен приложения (CORS + WebSocket). * = разрешить все
ALLOWED_ORIGIN=https://poker.yourcompany.com

# Через сколько часов удалять неактивные комнаты
ROOM_TTL_HOURS=8

# PostgreSQL (для docker-compose)
POSTGRES_USER=poker
POSTGRES_PASSWORD=your_strong_password_here

# Railway: вместо POSTGRES_USER/PASSWORD задайте DATABASE_URL напрямую:
# DATABASE_URL=jdbc:postgresql://host:5432/db?user=u&password=p
# DB_DRIVER=org.postgresql.Driver
